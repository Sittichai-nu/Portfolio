# Django settings
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# CSRF trusted origins (required in production)
CSRF_TRUSTED_ORIGINS=https://your-app.azurewebsites.net

# AI chat feature
AI_API_KEY=
AI_MODEL=

# Email settings (for contact form auto-reply)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Production only (set DEBUG=False first)
# SECURE_SSL_REDIRECT=False (Azure handles SSL at load balancer)
